{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["main", "unstable"],
  "enabledManagers": ["custom.regex"],
  "ignorePaths": ["**/hydenix-themes/**"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.nix$/"],
      "matchStrings": [
        "fetchFromGitHub\\s*{[^}]*owner = \"(?<depOwner>[^\"]+)\";[^}]*repo = \"(?<depName>[^\"]+)\";[^}]*rev = \"(?<currentValue>[^\"]+)\";"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "{{depOwner}}/{{depName}}",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^pkgs/hyde/default\\.nix$/"],
      "matchStrings": [
        "fetchFromGitHub\\s*{[^}]*owner = \"HyDE-Project\";[^}]*repo = \"HyDE\";[^}]*rev = \"(?<currentDigest>[^\"]+)\";"
      ],
      "currentValueTemplate": "dev",
      "depNameTemplate": "HyDE",
      "packageNameTemplate": "HyDE-Project/HyDE",
      "datasourceTemplate": "github-digest"
    }
  ],
  "packageRules": [
    {
      "matchBaseBranches": ["main"],
      "matchDatasources": ["github-releases"],
      "matchManagers": ["custom.regex"],
      "postUpgradeTasks": {
        "commands": ["nix run github:florianvazelle/nix-update -- {{depName}} --flake"],
        "executionMode": "update",
        "fileFilters": ["**/*.nix"]
      }
    },
    {
      "matchBaseBranches": ["unstable"],
      "matchDatasources": ["github-digest"],
      "matchManagers": ["custom.regex"],
      "postUpgradeTasks": {
        "commands": ["nix run github:florianvazelle/nix-update -- {{depName}} --flake --version=branch=dev --version-regex '(v[0-9][0-9]\\.[0-9]+\\.[0-9]+-unstable.*)'"],
        "executionMode": "update",
        "fileFilters": ["**/*.nix"]
      }
    }
  ]
}